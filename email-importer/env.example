# ─── Supabase ────────────────────────────────────────────
SUPABASE_URL=https://tzrwwnenkgzwgocmlaon.supabase.co
# service_role key → Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ─── Anthropic ───────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Mail Provider ───────────────────────────────────────
# 'gmail' sau 'yahoo'
MAIL_PROVIDER=gmail

# ─── Gmail ───────────────────────────────────────────────
GMAIL_USER=tu@gmail.com
# App Password: myaccount.google.com → Security → App passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Yahoo ───────────────────────────────────────────────
YAHOO_USER=tu@yahoo.com
# App Password: login.yahoo.com → Security → Generate app password
YAHOO_APP_PASSWORD=xxxxxxxxxxxx

# ─── Opțiuni import ──────────────────────────────────────
# Câte mailuri să proceseze la o rulare
FETCH_LIMIT=20
# Folderul de mailuri (INBOX, Sent, etc.)
MAILBOX=INBOX
